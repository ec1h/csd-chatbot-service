{
    "family": "csd-chatbot-test",
    "taskRoleArn": "arn:aws:iam::905418043725:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::905418043725:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "chatbot",
            "image": "905418043725.dkr.ecr.af-south-1.amazonaws.com/csd-chatbot-test:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8001,
                    "hostPort": 8001,
                    "protocol": "tcp",
                    "name": "chatbot-8001"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "USE_OPTIMIZED_PIPELINE",
                    "value": "true"
                },
                {
                    "name": "MAX_CLARIFICATION_TURNS",
                    "value": "3"
                },
                {
                    "name": "ENV",
                    "value": "test"
                },
                {
                    "name": "LOG_LEVEL",
                    "value": "DEBUG"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "POSTGRES_URI",
                    "valueFrom": "test/csd-chatbot/database"
                },
                {
                    "name": "AZURE_OPENAI_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:af-south-1:905418043725:secret:test/csd-chatbot/azure-openai-xC9TFZ:api_key::"
                },
                {
                    "name": "AZURE_OPENAI_ENDPOINT",
                    "valueFrom": "arn:aws:secretsmanager:af-south-1:905418043725:secret:test/csd-chatbot/azure-openai-xC9TFZ:endpoint::"
                },
                {
                    "name": "AZURE_OPENAI_DEPLOYMENT",
                    "valueFrom": "arn:aws:secretsmanager:af-south-1:905418043725:secret:test/csd-chatbot/azure-openai-xC9TFZ:deployment::"
                },
                {
                    "name": "AZURE_OPENAI_API_VERSION",
                    "valueFrom": "arn:aws:secretsmanager:af-south-1:905418043725:secret:test/csd-chatbot/azure-openai-xC9TFZ:api_version::"
                },
                {
                    "name": "AZURE_OPENAI_MODEL_NAME",
                    "valueFrom": "arn:aws:secretsmanager:af-south-1:905418043725:secret:test/csd-chatbot/azure-openai-xC9TFZ:deployment::"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/csd-chatbot-test",
                    "awslogs-region": "af-south-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:8001/health || exit 1"
                ],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            },
            "systemControls": []
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048"
}
